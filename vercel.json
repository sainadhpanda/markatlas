{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/markatlas-website/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "env": {
    "PORT": "3000",
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  },
  "framework": "vite",
  "regions": ["iad1"],
  "projectSettings": {
    "framework": "vite"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
